; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ProjectionMapping"
run/main_scene="res://scenes/bootstrap/Bootstrap.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[autoload]

Network="*res://autoloads/Network.gd"
SessionState="*res://autoloads/SessionState.gd"

[dotnet]

project/assembly_name="ProjectionMapping"

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://autoloads/": "yellow",
"res://scenes/": "blue",
"res://shaders/": "red"
}

[navigation]

3d/default_cell_size=0.08
3d/default_cell_height=0.1

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
